# Copy to .env.local and fill in values from https://dashboard.stripe.com
# Use Test mode keys while developing (sk_test_… / pk_test_…).
# Switch to Live keys (sk_live_… / pk_live_…) only when ready for real charges.

# Required — secret key (server only, never expose in HTML)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Optional for hosted Checkout (not required on the page; keep for other Stripe.js uses)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Required — Price ID from product setup (run: pnpm run stripe:create-product)
STRIPE_PRICE_ID=price_your_price_id_here

# Required for webhooks — from `stripe listen` (local) or Dashboard → Webhooks (prod)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public site URL used for success/cancel redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional overrides for scripts/create-stripe-product.mjs
# STRIPE_PRODUCT_NAME=Example Product
# STRIPE_UNIT_AMOUNT=2000
# STRIPE_CURRENCY=usd
